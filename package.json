{
  "name": "claw-zero",
  "version": "0.1.18",
  "description": "One-Click CLI to securely install and sandbox the OpenClaw AI agent",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "claw-zero": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test:e2e": "npx playwright test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "execa": "^9.5.2",
    "listr2": "^8.2.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
